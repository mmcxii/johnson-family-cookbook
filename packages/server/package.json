{
  "name": "@jfcb/server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "author": "Nich Secord",
  "license": "MIT",
  "scripts": {
    "ci:test": "yarn test",
    "docker:build": "yarn docker:up --build",
    "docker:down": "docker-compose down",
    "docker:nuke": "yarn docker:down && rm -rf docker-data/db-data",
    "docker:start": "yarn docker:up -d",
    "docker:up": "docker-compose up",
    "lint:fix": "eslint src/**/*.ts --fix",
    "server:build": "./node_modules/.bin/tsc",
    "start:dev": "yarn docker:start && yarn start:server:dev",
    "start:prod": "yarn docker:start && NODE_ENV=production yarn start:server:prod",
    "start:server:dev": "tsnd src/index.ts --respawn",
    "start:server:prod": "node dist/index.js",
    "test": "echo \"Haven't written any yet...\"",
    "typeorm:migration:create": "npx typeorm migration:create -n",
    "typeorm:migration:generate": "npx typeorm migration:generate -n",
    "typeorm:migration:revert": "npx typeorm migration:revert",
    "typeorm:migration:run": "npx typeorm migration:run",
    "typeorm:migration:run:ts": "ts-node ../../node_modules/typeorm/cli.js migration:run",
    "validate-server": "yarn lint:fix && yarn test"
  },
  "dependencies": {
    "apollo-server-express": "^2.11.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "find-up": "^4.1.0",
    "jsonwebtoken": "^8.5.1",
    "nodemailer": "^6.4.6",
    "pg": "^7.18.2",
    "reflect-metadata": "^0.1.13",
    "type-graphql": "^0.17.6",
    "typeorm": "^0.2.24",
    "uuid": "^7.0.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cookie-parser": "^1.4.2",
    "@types/cors": "^2.8.6",
    "@types/express": "^4.17.3",
    "@types/graphql": "^14.5.0",
    "@types/jsonwebtoken": "^8.3.8",
    "@types/node": "^13.9.5",
    "@types/nodemailer": "^6.4.0",
    "@types/uuid": "^7.0.2",
    "@typescript-eslint/eslint-plugin": "^2.25.0",
    "@typescript-eslint/parser": "^2.25.0",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-typescript": "^7.2.0",
    "eslint-config-prettier": "^6.10.1",
    "eslint-plugin-import": "^2.20.2",
    "husky": "^4.2.3",
    "ts-node-dev": "^1.0.0-pre.44",
    "typescript": "^3.8.3"
  }
}
